{
  "name": "JP Apex Lab",
  "short_name": "Apex Lab",
  "description": "Track telemetry and session analysis dashboard",
  "start_url": "/m3-dashboard/",
  "scope": "/m3-dashboard/",
  "display": "standalone",
  "orientation": "any",
  "background_color": "#0F0F14",
  "theme_color": "#0F0F14",
  "icons": [
    { "src": "/m3-dashboard/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "any" },
    { "src": "/m3-dashboard/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "any" },
    { "src": "/m3-dashboard/icons/icon-192.png", "sizes": "192x192", "type": "image/png", "purpose": "maskable" },
    { "src": "/m3-dashboard/icons/icon-512.png", "sizes": "512x512", "type": "image/png", "purpose": "maskable" }
  ],
  "share_target": {
    "action": "/m3-dashboard/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "session",
          "accept": ["text/csv", "application/json", ".csv", ".json"]
        }
      ]
    }
  }
}
