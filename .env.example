# ═══════════════════════════════════════════════════════════════════════════════
# Apex Lab Environment Configuration
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ── Required: Google OAuth ─────────────────────────────────────────────────────
# Create credentials at https://console.cloud.google.com/apis/credentials
# - Application type: Web application
# - Authorized JavaScript origins: http://localhost:5173, https://yourdomain.com
# - Authorized redirect URIs: same as origins
VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# ── Required: Google Drive Folder ──────────────────────────────────────────────
# Create a folder in Google Drive for session data storage
# The folder ID is the last part of the folder URL:
# https://drive.google.com/drive/folders/FOLDER_ID_HERE
VITE_GOOGLE_DRIVE_FOLDER_ID=

# ── Required: AI Coaching Proxy ────────────────────────────────────────────────
# Your Vercel deployment URL (handles Anthropic API calls server-side)
# Deploy the api/coaching.ts endpoint to Vercel first
VITE_COACHING_WORKER_URL=https://your-app.vercel.app

# ── Optional: App Branding ─────────────────────────────────────────────────────
# Customize the app name (appears in header, PWA manifest)
VITE_APP_NAME=Apex Lab

# Owner email for app identification (used for rate limiting)
VITE_OWNER_EMAIL=

# Custom logo path (relative to public folder)
VITE_APP_LOGO=/apex-lab/icons/icon-192.png

# ═══════════════════════════════════════════════════════════════════════════════
# Vercel Environment Variables (set in Vercel dashboard, NOT in .env)
# ═══════════════════════════════════════════════════════════════════════════════

# ANTHROPIC_API_KEY=sk-ant-...
# Your Anthropic API key for the coaching proxy
# Get one at https://console.anthropic.com/settings/keys

# ALLOWED_ORIGIN=https://yourdomain.github.io
# The origin URL where your app is deployed (for CORS)
# This must match exactly (including https://)

# ═══════════════════════════════════════════════════════════════════════════════
# GitHub Secrets (set in repo Settings > Secrets > Actions)
# ═══════════════════════════════════════════════════════════════════════════════
# These are used during GitHub Actions build:
# - VITE_GOOGLE_CLIENT_ID
# - VITE_COACHING_WORKER_URL
# - VITE_GOOGLE_DRIVE_FOLDER_ID
# - VITE_OWNER_EMAIL (optional)
# - VITE_APP_NAME (optional)
