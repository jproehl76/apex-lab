VITE_GOOGLE_CLIENT_ID=your-client-id-here.apps.googleusercontent.com

# AI Coaching proxy (Vercel deployment)
# Leave empty if users supply their own Anthropic key via Settings
VITE_COACHING_WORKER_URL=https://your-app.vercel.app

# Optional: server-side Anthropic key for the Vercel proxy (api/coaching.ts)
# Never expose this on the client, only set in Vercel environment variables
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: user's own key (browser to Anthropic direct, bypasses proxy)
# VITE_ANTHROPIC_API_KEY=sk-ant-...
